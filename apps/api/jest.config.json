{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src"],
  "testRegex": ".*\\.spec\\.ts$",
  "moduleFileExtensions": ["ts", "js", "json"],
  "collectCoverageFrom": ["**/*.(t|j)s"],
  "coverageDirectory": "../coverage",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
