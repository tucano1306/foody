{
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "outputDirectory": ".next",
  "installCommand": "pnpm install --frozen-lockfile",
  "crons": [
    {
      "path": "/api/cron/payments-reminder",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/payments-daily",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/stock-alerts",
      "schedule": "0 8 * * *"
    }
  ]
}
