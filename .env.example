# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://foody:foody_secret@localhost:5432/foody

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET=change-me-use-a-long-random-jwt-secret-string

# ─── Iron Session (Next.js BFF) ──────────────────────────────────────────────
# Must be at least 32 characters
IRON_SESSION_PASSWORD=change-me-use-a-long-random-iron-session-password

# ─── AWS S3 ──────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=foody-product-photos

# ─── OneSignal Push Notifications ────────────────────────────────────────────
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_API_KEY=your-onesignal-rest-api-key

# ─── App URLs ────────────────────────────────────────────────────────────────
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
