# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://foody:foody_secret@localhost:5432/foody

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET=change-me-use-a-long-random-jwt-secret-string

# ─── Iron Session (Next.js BFF) ──────────────────────────────────────────────
# Must be at least 32 characters
IRON_SESSION_PASSWORD=change-me-use-a-long-random-iron-session-password

# ─── AWS S3 ──────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=foody-product-photos

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────────
# Generate via: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_CONTACT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# ─── Vercel Cron Secret (set same value in Vercel env vars) ──────────────────
CRON_SECRET=change-me-random-secret-for-cron-jobs

# ─── App URLs ────────────────────────────────────────────────────────────────
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001

# ─── Email Auth (OTP via SMTP) ───────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
AUTH_EMAIL_FROM=Foody <auth@example.com>
